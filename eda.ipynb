        "# If Month is not already present, create it from Arrival Date\n",
        "df['Arrival Date'] = pd.to_datetime(df['Arrival Date'], errors='coerce')\n",
        "df['Month'] = df['Arrival Date'].dt.strftime('%b')   # Jan, Feb, Mar...\n",
        "\n",
        "# Make sure booking status is numeric\n",
        "df['Booking Status'] = pd.to_numeric(df['Booking Status'], errors='coerce')\n",
        "\n",
        "# Correct month order\n",
        "month_order = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',\n",
        "               'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']\n",
        "\n",
        "# Create summary table\n",
        "monthly_data = df.groupby('Month')['Booking Status'].value_counts().unstack(fill_value=0)\n",
        "\n",
        "# Reindex in correct order\n",
        "monthly_data = monthly_data.reindex(month_order, fill_value=0)\n",
        "\n",
        "print(monthly_data)   # check before plotting\n",
        "\n",
        "# Plot\n",
        "ax = monthly_data.plot(kind='bar', figsize=(12,5), color=['steelblue', 'salmon'])\n",
        "plt.title(\"Monthly Booking vs Cancellation Trend\")\n",
        "plt.xlabel(\"Month\")\n",
        "plt.ylabel(\"Number of Bookings\")\n",
        "plt.legend(['Not Cancelled (0)', 'Cancelled (1)'], loc='upper left', bbox_to_anchor=(1,1))\n",
        "plt.xticks(rotation=0)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
