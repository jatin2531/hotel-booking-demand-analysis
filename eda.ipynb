      "source": [
        "# Monthly ADR Trend\n",
        "plt.figure(figsize=(10,5))\n",
        "month_order = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']\n",
        "\n",
        "# Create a temporary mapping for numerical months to month names\n",
        "# Assuming df['Month'] column contains integers 1-12\n",
        "month_name_map = {i+1: month for i, month in enumerate(month_order)}\n",
        "# Map the numerical 'Month' column to month names for grouping\n",
        "monthly_adr = df.groupby(df['Month'].map(month_name_map))['Average Daily Rate'].mean()\n",
        "\n",
        "# Reindex to ensure all months are present and in the correct order, filling missing with NaN\n",
        "monthly_adr = monthly_adr.reindex(month_order)\n",
        "\n",
        "# Line plot\n",
        "plt.plot(monthly_adr.index, monthly_adr.values, marker='o', color='steelblue')\n",
        "plt.title(\"Monthly ADR Trend (Seasonality)\")\n",
        "plt.xlabel(\"Month\")\n",
        "plt.ylabel(\"Average Daily Rate\")\n",
        "plt.grid(True, linestyle='--', alpha=0.5)\n",
        "\n",
        "# Highlight Top 3 peak months\n",
        "# Filter out NaN values before sorting for peak months calculation\n",
        "top3 = monthly_adr.dropna().sort_values(ascending=False).head(3)\n",
        "if not top3.empty: # Only plot if there are valid top3 months\n",
        "    plt.scatter(top3.index, top3.values, color='red', s=100, label='Top 3 Peak Months')\n",
        "plt.legend()\n",
        "plt.show()"
      ]
